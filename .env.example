# ── Auth ───────────────────────────────────────────────────────────────────────
# Long-lived OAuth token from `claude setup-token` (Claude Max subscription required)
CLAUDE_CODE_OAUTH_TOKEN=

# Classic GitHub PAT — repo + workflow scopes
GH_TOKEN=

# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Discord server (guild) ID
DISCORD_GUILD_ID=

# General channel — catch-all, mention required
DISCORD_CHANNEL_GENERAL=

# claw self-maintenance channel — source edits → build → restart happen here
DISCORD_CHANNEL_CLAW=

# Optional: channel where Gmail alert threads are posted (defaults to DISCORD_CHANNEL_GENERAL)
DISCORD_CHANNEL_MAIL_ALERTS=

# Discord user ID of the operator (the only allowed sender)
DISCORD_OWNER_USER_ID=

# ── Gmail ──────────────────────────────────────────────────────────────────────
# Single OAuth client used for all Gmail accounts.
# Create at: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Refresh tokens — one per Gmail account listed in claw.config.json (in order).
# Generate each token with: tsx scripts/gmail-auth.ts <email>
GMAIL_REFRESH_TOKEN_1=
GMAIL_REFRESH_TOKEN_2=
# Add GMAIL_REFRESH_TOKEN_3, _4, … as needed

# ── Polling ────────────────────────────────────────────────────────────────────
MAIL_POLL_INTERVAL_SEC=600

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3200
DASHBOARD_SECRET=

# ── Paths ──────────────────────────────────────────────────────────────────────
DATA_DIR=
LOGS_DIR=
