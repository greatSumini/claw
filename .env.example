# ── Auth ───────────────────────────────────────────────────────────────
# Long-lived OAuth token from `claude setup-token` (Max subscription)
CLAUDE_CODE_OAUTH_TOKEN=

# Classic GitHub PAT — repo + workflow scopes
GH_TOKEN=

# ── Discord ────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Discord server (guild) and channel IDs
DISCORD_GUILD_ID=
DISCORD_CHANNEL_GENERAL=
DISCORD_CHANNEL_LIFE_OS=
DISCORD_CHANNEL_VMC_CONTEXT_HUB=
DISCORD_CHANNEL_ARGOS=
DISCORD_CHANNEL_VOOSTER=
DISCORD_CHANNEL_INBOX=

# Discord user ID of the operator (the only allowed sender)
DISCORD_OWNER_USER_ID=

# ── Gmail (4 accounts) ─────────────────────────────────────────────────
# Single OAuth client for all accounts. Generated once at:
#   https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Refresh tokens — one per account. Generated by `tsx scripts/gmail-auth.ts`
GMAIL_REFRESH_TOKEN_GREATSUMINI=
GMAIL_REFRESH_TOKEN_CURSORMATFIA=
GMAIL_REFRESH_TOKEN_LEAD_AWESOMEDEV=
GMAIL_REFRESH_TOKEN_SUMIN_VOOSTER=

# ── Polling ────────────────────────────────────────────────────────────
MAIL_POLL_INTERVAL_SEC=600

# ── Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_PORT=3200
DASHBOARD_SECRET=

# ── Paths ──────────────────────────────────────────────────────────────
REPOS_DIR=/Users/sumin/repos
DATA_DIR=/Users/sumin/repos/greatSumini/claw/data
LOGS_DIR=/Users/sumin/repos/greatSumini/claw/logs
